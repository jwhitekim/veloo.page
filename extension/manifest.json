{
  "manifest_version": 3,
  "name": "Paper Analyzer",
  "version": "1.0.3",
  "description": "PDF 논문을 드래그하거나 선택해서 즉시 분석",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Paper Analyzer"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+P",
        "mac": "Alt+P"
      },
      "description": "Paper Analyzer 열기"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "http://localhost:9000/*",
    "https://lab-toolkit.fly.dev/*"
  ]
}
